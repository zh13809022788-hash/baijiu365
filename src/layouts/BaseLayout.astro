---
import SeoJsonLd from '../components/SeoJsonLd.astro';

interface Props {
  title: string;
  description: string;
  keywords?: string[];
  type?: 'WebSite' | 'Article' | 'AboutPage';
  canonicalPath?: string;
  noindex?: boolean;
  image?: string;
  datePublished?: string;
  dateModified?: string;
  authorName?: string;
  authorUrl?: string;
}

const {
  title,
  description,
  keywords,
  type = 'Article',
  canonicalPath,
  noindex = false,
  image,
  datePublished,
  dateModified,
  authorName,
  authorUrl,
} = Astro.props;
const siteUrl = 'https://baijiu365.com';
const canonical = new URL(canonicalPath ?? Astro.url.pathname, siteUrl).toString();
const socialImage = image ?? 'https://baijiu365.com/images/baijiu-field-guide.png';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {keywords && keywords.length > 0 && <meta name="keywords" content={keywords.join(', ')} />}
    {noindex && <meta name="robots" content="noindex, follow" />}
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title="Baijiu365 RSS" href="/rss.xml" />
    <meta property="og:site_name" content="Baijiu365" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type === 'WebSite' ? 'website' : 'article'} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta name="twitter:card" content="summary" />
    <SeoJsonLd
      type={type}
      title={title}
      description={description}
      url={canonical}
      image={socialImage}
      datePublished={datePublished}
      dateModified={dateModified}
      authorName={authorName}
      authorUrl={authorUrl}
    />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label="Baijiu365 home">Baijiu365</a>
      <nav aria-label="Primary navigation">
        <a href="/baijiu-basics/">Basics</a>
        <a href="/types-of-baijiu/">Types</a>
        <a href="/best-baijiu-for-beginners/">Beginners</a>
        <a href="/how-to-buy-baijiu-outside-china/">Buying</a>
        <a href="/how-to-spot-fake-maotai/">Fake Maotai</a>
        <a href="/brands/maotai/">Maotai</a>
        <a href="/glossary/">Glossary</a>
        <a href="/db/variety/maotai/">Database</a>
        <a href="/editorial-team/">Team</a>
        <a href="/about/">About</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="footer-inner">
        <p>Baijiu365 is an independent field guide to Chinese baijiu for curious drinkers, hosts, collectors, and bartenders.</p>
        <nav aria-label="Footer navigation">
          <a href="/baijiu-basics/">Basics</a>
          <a href="/types-of-baijiu/">Aroma types</a>
          <a href="/best-baijiu-for-beginners/">Beginner buying</a>
          <a href="/glossary/">Glossary</a>
          <a href="/editorial-policy/">Editorial policy</a>
          <a href="/affiliate-disclosure/">Affiliate disclosure</a>
          <a href="/privacy/">Privacy</a>
          <a href="/terms/">Terms</a>
          <a href="/contact/">Contact</a>
        </nav>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --ink: #201d1a;
    --muted: #695f55;
    --line: #ddd6cb;
    --paper: #fbfaf7;
    --panel: #ffffff;
    --red: #a72f24;
    --gold: #b9822b;
    --green: #536b45;
    --blue: #3b6074;
    --shadow: 0 12px 30px rgba(32, 29, 26, 0.09);
  }

  * { box-sizing: border-box; }

  body {
    margin: 0;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    color: var(--ink);
    background: var(--paper);
    line-height: 1.65;
  }

  a { color: inherit; }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 16px clamp(18px, 4vw, 56px);
    border-bottom: 1px solid rgba(221, 214, 203, 0.85);
    background: rgba(251, 250, 247, 0.94);
    backdrop-filter: blur(12px);
  }

  .brand {
    flex: 0 0 auto;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 22px;
    font-weight: 700;
    text-decoration: none;
  }

  nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 8px 18px;
    color: var(--muted);
    font-size: 14px;
  }

  nav a {
    text-decoration: none;
  }

  nav a:hover { color: var(--red); }

  main { min-height: 70vh; }

  .section {
    padding: clamp(48px, 8vw, 92px) clamp(18px, 4vw, 56px);
  }

  .section.tight { padding-top: 34px; }

  .wrap {
    width: min(1120px, 100%);
    margin: 0 auto;
  }

  .narrow {
    width: min(760px, 100%);
    margin: 0 auto;
  }

  .hero {
    min-height: calc(100vh - 72px);
    display: grid;
    align-items: center;
    padding: clamp(32px, 6vw, 72px) clamp(18px, 4vw, 56px) 42px;
    background:
      linear-gradient(110deg, rgba(32, 29, 26, 0.9) 0%, rgba(32, 29, 26, 0.75) 43%, rgba(32, 29, 26, 0.2) 100%),
      linear-gradient(135deg, #37231f 0%, #7a2d25 46%, #d8b36d 100%);
    color: #fffdf8;
    overflow: hidden;
  }

  .hero-inner {
    width: min(1120px, 100%);
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(260px, 0.75fr);
    align-items: center;
    gap: clamp(28px, 6vw, 76px);
  }

  .hero-copy { max-width: 680px; }

  .eyebrow {
    margin: 0 0 14px;
    color: #f0d7a2;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  h1, h2, h3 {
    font-family: Georgia, "Times New Roman", serif;
    line-height: 1.08;
    letter-spacing: 0;
  }

  h1 {
    margin: 0;
    font-size: clamp(48px, 8vw, 96px);
    max-width: 11ch;
  }

  h2 {
    margin: 0 0 18px;
    font-size: clamp(30px, 5vw, 54px);
  }

  h3 {
    margin: 0 0 10px;
    font-size: 24px;
  }

  .lede {
    max-width: 680px;
    margin: 22px 0 0;
    color: rgba(255, 253, 248, 0.86);
    font-size: clamp(18px, 2.1vw, 23px);
    line-height: 1.45;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 30px;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 10px 18px;
    border: 1px solid transparent;
    border-radius: 6px;
    background: #fffdf8;
    color: var(--ink);
    font-weight: 700;
    text-decoration: none;
  }

  .button.secondary {
    border-color: rgba(255, 253, 248, 0.48);
    background: transparent;
    color: #fffdf8;
  }

  .hero-media {
    align-self: stretch;
    min-height: 430px;
  }

  .hero-media img {
    width: 100%;
    height: 100%;
    min-height: 430px;
    object-fit: cover;
    border: 1px solid rgba(255, 253, 248, 0.28);
    border-radius: 8px;
    box-shadow: 0 24px 60px rgba(20, 14, 12, 0.28);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .card {
    min-height: 190px;
    padding: 24px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--panel);
    box-shadow: 0 2px 0 rgba(32, 29, 26, 0.03);
  }

  .card p, .narrow p, li { color: var(--muted); }

  .card a {
    color: var(--red);
    font-weight: 700;
    text-decoration: none;
  }

  .profile-list {
    display: grid;
    gap: 18px;
  }

  .profile-card {
    padding: 24px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #fff;
  }

  .profile-card h2 {
    margin-top: 0;
    font-size: 30px;
  }

  .pathway {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
    margin-top: 24px;
  }

  .pathway a,
  .next-links a {
    display: block;
    padding: 18px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #fff;
    color: var(--red);
    font-weight: 700;
    text-decoration: none;
  }

  .article-header {
    padding: clamp(48px, 8vw, 88px) clamp(18px, 4vw, 56px) 26px;
    border-bottom: 1px solid var(--line);
    background: #f5efe4;
  }

  .article-header h1 {
    max-width: 820px;
    color: var(--ink);
    font-size: clamp(40px, 7vw, 78px);
  }

  .article-header .lede {
    color: var(--muted);
  }

  .content {
    padding: 40px clamp(18px, 4vw, 56px) 80px;
  }

  .content article {
    width: min(760px, 100%);
    margin: 0 auto;
  }

  .content article h2 {
    margin-top: 42px;
    font-size: 34px;
  }

  .callout {
    margin: 28px 0;
    padding: 20px;
    border-left: 4px solid var(--red);
    background: #fff;
  }

  .decision-box {
    margin: 28px 0;
    padding: 22px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #fff;
  }

  .feature-band,
  .split {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(280px, 1fr);
    gap: clamp(24px, 6vw, 72px);
    align-items: start;
    padding: clamp(28px, 5vw, 48px) 0;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  .feature-band .eyebrow,
  .split .eyebrow {
    color: var(--red);
  }

  .feature-list {
    display: grid;
    gap: 12px;
  }

  .feature-list a {
    display: block;
    padding: 18px 20px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #fff;
    color: var(--ink);
    font-weight: 700;
    text-decoration: none;
  }

  .feature-list a:hover {
    border-color: rgba(167, 47, 36, 0.55);
    color: var(--red);
  }

  .feature-list.compact a {
    min-height: 62px;
  }

  .split p {
    color: var(--muted);
    font-size: 18px;
  }

  .trust-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: center;
    padding: 18px 0;
    border-top: 1px solid var(--line);
    color: var(--muted);
    font-size: 14px;
  }

  .trust-strip span,
  .trust-strip a {
    padding: 8px 12px;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: #fff;
    text-decoration: none;
  }

  .decision-box h2,
  .decision-box h3 {
    margin-top: 0;
  }

  .table-wrap {
    margin: 24px 0;
    overflow-x: auto;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #fff;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    min-width: 620px;
    font-size: 15px;
  }

  th,
  td {
    padding: 14px 16px;
    border-bottom: 1px solid var(--line);
    text-align: left;
    vertical-align: top;
  }

  th {
    color: var(--ink);
    background: #f5efe4;
  }

  tr:last-child td {
    border-bottom: 0;
  }

  .faq {
    margin-top: 42px;
    padding-top: 12px;
    border-top: 1px solid var(--line);
  }

  .faq h2 {
    margin-top: 0;
  }

  .faq h3 {
    margin-top: 24px;
  }

  .next-links {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
    margin-top: 36px;
    padding-top: 24px;
    border-top: 1px solid var(--line);
  }

  .site-footer {
    padding: 28px clamp(18px, 4vw, 56px);
    border-top: 1px solid var(--line);
    color: var(--muted);
    background: #f5efe4;
  }

  .footer-inner {
    width: min(1120px, 100%);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .site-footer p {
    margin: 0;
    max-width: 620px;
  }

  @media (max-width: 860px) {
    .site-header { align-items: flex-start; flex-direction: column; }
    nav { justify-content: flex-start; }
    .hero { min-height: auto; }
    .hero-inner { grid-template-columns: 1fr; }
    .hero-media { min-height: 260px; }
    .hero-media img { min-height: 260px; }
    .grid { grid-template-columns: 1fr; }
    .feature-band, .split { grid-template-columns: 1fr; }
    .pathway, .next-links { grid-template-columns: 1fr; }
    .footer-inner { align-items: flex-start; flex-direction: column; }
  }
</style>
