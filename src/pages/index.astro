---
import BaseLayout from '../layouts/BaseLayout.astro';
import GuideCard from '../components/GuideCard.astro';

const title = 'Baijiu365 — The World\'s Most Comprehensive English-Language Baijiu Database';
const description = 'Baijiu365: 16 iconic Chinese baijiu varieties across 6 aroma types (sauce, strong, light, phoenix, herbal, mixed) and 8 producing regions. Every entry includes verified GB/T national standards, ABV ranges, raw ingredients, tasting notes, and buying guides. Compare baijiu by aroma, region, price tier, and production method.';
const keywords = [
  'baijiu database', 'Chinese liquor guide', 'baijiu aroma types',
  'GB/T baijiu standards', 'sauce aroma baijiu', 'strong aroma baijiu',
  'light aroma baijiu', 'Maotai guide', 'Wuliangye', 'Fenjiu',
  'baijiu buying guide', 'Chinese spirits database', 'baijiu for beginners',
  'how to buy baijiu', 'baijiu flavor wheel', 'baijiu region guide'
];
---
<BaseLayout title={title} description={description} keywords={keywords} type="WebSite">
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-copy">
        <p class="eyebrow">Independent Chinese spirits guide</p>
        <h1>Baijiu365</h1>
        <p class="lede">A practical field guide for people who need to understand baijiu before they drink it, buy it, gift it, serve it, or explain it to someone else.</p>
        <div class="actions">
          <a class="button" href="/baijiu-basics/">Start Here</a>
          <a class="button secondary" href="/best-baijiu-for-beginners/">Choose a first bottle</a>
        </div>
      </div>
      <div class="hero-media">
        <img src="/images/baijiu-field-guide.png" alt="Illustrated baijiu bottle, tasting glass, and grain on a warm table" />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <h2>Use The Site By Decision</h2>
      <div class="grid">
        <GuideCard href="/baijiu-basics/" title="I Need the Basics" text="What baijiu is, why it is not vodka, how aroma types work, and why one bad banquet glass should not define the category." />
        <GuideCard href="/types-of-baijiu/" title="I Need to Understand Flavor" text="Compare sauce, strong, light, and rice aroma by taste, intensity, beginner difficulty, and best use case." />
        <GuideCard href="/best-baijiu-for-beginners/" title="I Need a First Bottle" text="Pick a bottle by occasion, aroma type, alcohol strength, budget, and buying channel instead of prestige alone." />
        <GuideCard href="/how-to-buy-baijiu-outside-china/" title="I Am Buying Overseas" text="What to check before buying baijiu outside China, from importer labels to suspicious gift boxes and marketplace listings." />
        <GuideCard href="/how-to-spot-fake-maotai/" title="I Am Worried About Fake Maotai" text="A risk-first guide to counterfeits, refilled bottles, development products, vintage claims, and price signals." />
        <GuideCard href="/baijiu-flavor-wheel/" title="I Want Better Tasting Language" text="A simple flavor framework for describing grain, fruit, fermentation, savory notes, texture, heat, and finish." />
      </div>
    </div>
  </section>

  <section class="section tight">
    <div class="wrap">
      <div class="feature-band">
        <div>
          <p class="eyebrow">Flavor and aroma map</p>
          <h2>Read baijiu by style, not by bottle shape.</h2>
        </div>
        <div class="feature-list">
          <a href="/types-of-baijiu/">Compare sauce, strong, light, and rice aroma</a>
          <a href="/baijiu-flavor-wheel/">Name fruit, grain, savory, heat, and finish notes</a>
          <a href="/baijiu-vs-vodka/">Explain why clear baijiu is not neutral vodka</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section tight">
    <div class="wrap">
      <h2>Core Reading Path</h2>
      <div class="pathway">
        <a href="/baijiu-basics/">1. Learn what baijiu is before comparing brands</a>
        <a href="/types-of-baijiu/">2. Use aroma type to predict flavor and intensity</a>
        <a href="/best-baijiu-for-beginners/">3. Choose a first bottle by use case, not status</a>
        <a href="/how-to-drink-baijiu/">4. Serve it with food, small pours, and realistic pacing</a>
      </div>
    </div>
  </section>

  <section class="section tight">
    <div class="wrap">
      <div class="split">
        <div>
          <p class="eyebrow">Buying risk center</p>
          <h2>Use caution before prestige.</h2>
          <p>Baijiu buying can involve counterfeits, refilled bottles, vague development labels, inflated gift packaging, and listings that are hard to verify outside China. The safest path is to separate drinking needs from status needs before spending.</p>
        </div>
        <div class="feature-list compact">
          <a href="/how-to-buy-baijiu-outside-china/">Overseas buying checks</a>
          <a href="/how-to-spot-fake-maotai/">Fake Maotai risk signals</a>
          <a href="/brands/maotai/">Maotai context for beginners</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section tight">
    <div class="wrap">
      <div class="split">
        <div>
          <p class="eyebrow">Baijiu Database</p>
          <h2>Compare baijiu by hard data, not marketing.</h2>
          <p>16 varieties across 6 aroma types and 8 producing regions. Every entry includes verified GB/T standard codes, ABV ranges, raw ingredient lists, tasting notes, and price-tiered buying guidance — no tasting-room poetry.</p>
        </div>
        <div class="feature-list compact">
          <a href="/db/variety/maotai/">Maotai — GB/T 18356, Guizhou sauce aroma</a>
          <a href="/db/variety/wuliangye/">Wuliangye — five-grain strong aroma</a>
          <a href="/db/variety/fenjiu/">Fenjiu — the light aroma benchmark</a>
          <a href="/db/aroma/sauce/">Browse all sauce-aroma varieties</a>
          <a href="/db/aroma/strong/">Browse all strong-aroma varieties</a>
          <a href="/db/region/sichuan/">Sichuan region — 6 varieties</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section tight">
    <div class="wrap">
      <div class="trust-strip">
        <span>Independent guide</span>
        <span>No paid placements yet</span>
        <span>Practical limits stated</span>
        <a href="/editorial-policy/">Editorial policy</a>
      </div>
    </div>
  </section>
</BaseLayout>
