---
import BaseLayout from '../../layouts/BaseLayout.astro';
const title = 'Baijiu365 Editorial Team';
const description = 'Author profile for the Baijiu365 Editorial Team.';
---
<BaseLayout title={title} description={description} type="AboutPage">
  <header class="article-header">
    <div class="narrow">
      <p class="eyebrow">Author</p>
      <h1>Baijiu365 Editorial Team</h1>
      <p class="lede">The team profile used for Baijiu365 guides, updates, and corrections.</p>
    </div>
  </header>
  <section class="content">
    <article>
      <p>The Baijiu365 Editorial Team writes and maintains practical baijiu guides for global readers. The team's work focuses on aroma type, beginner buying decisions, overseas retail risk, drinking context, and plain-English explanations of Chinese spirits terminology.</p>
      <div class="callout"><strong>Disclosure:</strong> Baijiu365 does not currently sell baijiu, run affiliate links, publish sponsored reviews, or authenticate individual bottles.</div>
      <div class="next-links">
        <a href="/editorial-team/">Editorial team</a>
        <a href="/editorial-policy/">Editorial policy</a>
      </div>
    </article>
  </section>
</BaseLayout>
