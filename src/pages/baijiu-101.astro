---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Baijiu Basics Has Moved';
const description = 'The beginner baijiu guide now lives at Baijiu Basics.';
---
<BaseLayout title={title} description={description} canonicalPath="/baijiu-basics/" noindex={true}>
  <header class="article-header">
    <div class="narrow">
      <p class="eyebrow">Moved</p>
      <h1>Baijiu Basics</h1>
      <p class="lede">The beginner guide now lives at <a href="/baijiu-basics/">Baijiu Basics</a>.</p>
    </div>
  </header>
  <section class="content">
    <article>
      <p>This old entry point is kept only so existing links do not break.</p>
      <div class="next-links">
        <a href="/baijiu-basics/">Go to Baijiu Basics</a>
        <a href="/">Return to Baijiu365</a>
      </div>
    </article>
  </section>
</BaseLayout>
