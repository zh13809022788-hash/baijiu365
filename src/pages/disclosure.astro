---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Affiliate Disclosure Has Moved';
const description = 'The Baijiu365 affiliate disclosure now lives at /affiliate-disclosure/.';
---
<BaseLayout title={title} description={description} canonicalPath="/affiliate-disclosure/" noindex={true}>
  <header class="article-header"><div class="narrow"><p class="eyebrow">Moved</p><h1>Affiliate Disclosure</h1><p class="lede">The disclosure page now lives at <a href="/affiliate-disclosure/">Affiliate Disclosure</a>.</p></div></header>
  <section class="content"><article>
    <p>This old entry point is kept only so existing links do not break.</p>
    <div class="next-links">
      <a href="/affiliate-disclosure/">Go to Affiliate Disclosure</a>
      <a href="/editorial-policy/">Read Editorial Policy</a>
    </div>
  </article></section>
</BaseLayout>
