---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Terms - Baijiu365';
const description = 'Terms of use for Baijiu365, an independent baijiu information site.';
---
<BaseLayout title={title} description={description}>
  <header class="article-header"><div class="narrow"><p class="eyebrow">Policy</p><h1>Terms</h1><p class="lede">Use Baijiu365 as general information, not professional legal, medical, or authentication advice.</p></div></header>
  <section class="content"><article>
    <h2>General Information</h2>
    <p>Baijiu365 provides educational content about Chinese baijiu, drinking context, flavor, brands, and buying risks. Content may be incomplete or change as the market changes.</p>
    <h2>Responsible Drinking</h2>
    <p>Alcohol should be consumed only by adults of legal drinking age in their location. Do not drink and drive, and avoid pressure-based drinking situations.</p>
    <h2>No Bottle Authentication</h2>
    <p>Guides about fake bottles and buying risk are general risk frameworks. They do not authenticate a specific bottle or guarantee a purchase is genuine.</p>
  </article></section>
</BaseLayout>
