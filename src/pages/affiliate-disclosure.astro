---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Affiliate Disclosure - Baijiu365';
const description = 'Current affiliate, sponsorship, and commercial disclosure for Baijiu365.';
---
<BaseLayout title={title} description={description}>
  <header class="article-header"><div class="narrow"><p class="eyebrow">Disclosure</p><h1>Affiliate Disclosure</h1><p class="lede">Baijiu365 should be clear about commercial relationships before they affect content.</p></div></header>
  <section class="content"><article>
    <div class="decision-box">
      <h2>Current status</h2>
      <p>Baijiu365 does not currently run affiliate links, paid bottle placements, sponsored reviews, sample-driven ratings, or direct alcohol sales.</p>
    </div>
    <h2>How Future Relationships Will Be Handled</h2>
    <p>If affiliate links, retailer partnerships, sample bottles, advertising, or sponsorships are introduced later, we will disclose the relationship on this page and on any affected guide.</p>
    <h2>Editorial Independence</h2>
    <p>Commercial relationships should not decide whether a bottle, brand, or retailer is described as safe, suitable, beginner-friendly, or worth buying. Buying-risk warnings will remain part of the editorial standard.</p>
    <div class="next-links">
      <a href="/editorial-policy/">Editorial policy</a>
      <a href="/contact/">Contact Baijiu365</a>
    </div>
  </article></section>
</BaseLayout>
