---
import BaseLayout from '../../layouts/BaseLayout.astro';
import fs from 'fs';
import path from 'path';

// Load all variety JSON files
const varietiesDir = path.resolve(process.cwd(), 'data_pipeline/varieties');
const files = fs.readdirSync(varietiesDir).filter(f => f.endsWith('.json'));
const varieties = files.map(f => {
  const data = JSON.parse(fs.readFileSync(path.join(varietiesDir, f), 'utf-8'));
  return data;
});

// Group by aroma type
const aromaGroups = {};
for (const v of varieties) {
  if (!aromaGroups[v.aroma_type]) aromaGroups[v.aroma_type] = [];
  aromaGroups[v.aroma_type].push(v);
}

// Group by region
const regionGroups = {};
for (const v of varieties) {
  if (!regionGroups[v.region]) regionGroups[v.region] = [];
  regionGroups[v.region].push(v);
}

const aromaLabels = {
  sauce: 'Sauce Aroma', strong: 'Strong Aroma', light: 'Light Aroma',
  phoenix: 'Phoenix Aroma', herbal: 'Herbal Aroma', mixed: 'Mixed Aroma',
  rice: 'Rice Aroma', sesame: 'Sesame Aroma', fuyu: 'Fuyu Aroma',
  te: 'Te Aroma', chi: 'Chi Aroma', la: 'La Aroma',
};

const title = 'Baijiu Database — 16 Varieties Across 6 Aroma Types | Baijiu365';
const description = `Complete baijiu parameter database: ${varieties.length} varieties, ${Object.keys(aromaGroups).length} aroma types, ${Object.keys(regionGroups).length} producing regions. Every entry includes GB/T standards, ABV, ingredients, tasting notes, and buying guides.`;
const keywords = ['baijiu database', 'baijiu varieties', 'baijiu parameters', 'GB/T baijiu standards', 'baijiu comparison'];
---

<BaseLayout title={title} description={description} keywords={keywords} type="WebSite">
  <section class="article-header">
    <div class="wrap">
      <p class="eyebrow">Baijiu Parameter Database</p>
      <h1>Baijiu Database</h1>
      <p class="lede">{varieties.length} varieties &middot; {Object.keys(aromaGroups).length} aroma types &middot; {Object.keys(regionGroups).length} producing regions &middot; Every entry verified against GB/T national standards.</p>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <h2>Browse by Aroma Type</h2>
      <div class="grid">
        {Object.entries(aromaGroups).map(([type, items]) => (
          <a class="card-link" href={`/db/aroma/${type}/`}>
            <h3>{aromaLabels[type] || type}</h3>
            <p>{items.length} varieties</p>
            <span class="card-ids">{items.map(v => v.name_cn).join(' / ')}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section tight">
    <div class="wrap">
      <h2>Browse by Producing Region</h2>
      <div class="region-grid">
        {Object.entries(regionGroups).map(([region, items]) => (
          <a class="region-card" href={`/db/region/${region.toLowerCase()}/`}>
            <h3>{region}</h3>
            <p>{items.length} {items.length === 1 ? 'variety' : 'varieties'}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section tight">
    <div class="wrap">
      <h2>All Varieties</h2>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Variety</th>
              <th>Aroma</th>
              <th>ABV</th>
              <th>GB/T Standard</th>
              <th>Region</th>
              <th>Tier</th>
            </tr>
          </thead>
          <tbody>
            {varieties.map(v => (
              <tr>
                <td><a href={`/db/variety/${v.id}/`}>{v.name} ({v.name_cn})</a></td>
                <td><a href={`/db/aroma/${v.aroma_type}/`}>{aromaLabels[v.aroma_type] || v.aroma_type}</a></td>
                <td>{v.abv_range}</td>
                <td>{v.gbt_standard}</td>
                <td><a href={`/db/region/${v.region.toLowerCase()}/`}>{v.region}</a></td>
                <td>{v.tier}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .card-link {
    display: block;
    padding: 24px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--panel);
    text-decoration: none;
    color: var(--ink);
    transition: border-color 0.2s;
  }
  .card-link:hover { border-color: var(--red); }
  .card-link h3 { margin: 0 0 6px; font-size: 20px; }
  .card-link p { margin: 0 0 10px; color: var(--red); font-weight: 700; font-size: 14px; }
  .card-ids { font-size: 13px; color: var(--muted); }

  .region-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 14px;
  }
  .region-card {
    display: block;
    padding: 20px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--panel);
    text-decoration: none;
    color: var(--ink);
    text-align: center;
  }
  .region-card:hover { border-color: var(--red); }
  .region-card h3 { margin: 0 0 4px; font-size: 18px; }
  .region-card p { margin: 0; font-size: 13px; color: var(--muted); }

  @media (max-width: 860px) {
    .region-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
