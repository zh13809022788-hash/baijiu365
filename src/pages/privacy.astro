---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Privacy Policy - Baijiu365';
const description = 'A plain-language privacy policy for Baijiu365.';
---
<BaseLayout title={title} description={description}>
  <header class="article-header"><div class="narrow"><p class="eyebrow">Policy</p><h1>Privacy Policy</h1><p class="lede">Baijiu365 is a static information site and aims to collect as little personal data as possible.</p></div></header>
  <section class="content"><article>
    <h2>Information We Collect</h2>
    <p>Baijiu365 does not currently run user accounts, comments, checkout, or newsletter forms. Hosting providers may process standard server logs such as IP address, browser, referring page, and request time for security and reliability.</p>
    <h2>Analytics And Advertising</h2>
    <p>The site is not currently using advertising or personalized ad tracking. If analytics or advertising tools are added later, this page should be updated before launch.</p>
    <h2>Contact</h2>
    <p>If you contact the project directly, the information you provide may be used to respond to that message and improve the site.</p>
  </article></section>
</BaseLayout>
