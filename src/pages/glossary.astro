---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Baijiu Glossary: Essential Terms for Beginners';
const description = 'A beginner glossary for baijiu terms including qu, aroma type, sauce aroma, strong aroma, light aroma, and Maotai.';
---
<BaseLayout title={title} description={description}>
  <header class="article-header"><div class="narrow"><p class="eyebrow">Reference</p><h1>Baijiu Glossary</h1><p class="lede">A plain-English reference for the terms that appear again and again in baijiu buying, tasting, and production.</p></div></header>
  <section class="content"><article>
    <h2>Qu</h2><p>A fermentation starter made with grains and microbes. Qu is one reason baijiu develops such distinctive aromas.</p>
    <h2>Aroma Type</h2><p>The main style classification for baijiu. It is more useful than judging bottles by color.</p>
    <h2>Sauce Aroma</h2><p>A savory, complex aroma style made famous by Maotai.</p>
    <h2>Strong Aroma</h2><p>A rich, often fruity and cellar-influenced style common across many Chinese banquet bottles.</p>
    <h2>Light Aroma</h2><p>A cleaner, grain-forward style that can be easier to understand for some first-time drinkers.</p>
    <h2>Development Bottle</h2><p>A bottle connected to a major brand group or authorized producer but not necessarily equivalent to the core flagship product. These require careful reading before purchase.</p>
  </article></section>
</BaseLayout>
