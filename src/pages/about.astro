---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'About Baijiu365';
const description = 'Baijiu365 is an independent guide to Chinese baijiu, focused on practical judgment, transparent standards, and useful explanations for global readers.';
---
<BaseLayout title={title} description={description} type="AboutPage">
  <header class="article-header"><div class="narrow"><p class="eyebrow">About</p><h1>About Baijiu365</h1><p class="lede">Baijiu365 exists to make Chinese baijiu easier to understand without making it shallow.</p></div></header>
  <section class="content"><article>
    <h2>Editorial Standard</h2><p>We write for readers who need practical judgment: what to buy, how to drink, what to avoid, and how to understand flavor. We avoid fake authority, empty cultural slogans, and undisclosed sales pressure.</p>
    <h2>What We Cover</h2><p>Baijiu aroma types, beginner choices, brand context, drinking etiquette, cocktail use, buying risks, and the social situations where baijiu actually appears.</p>
    <h2>What Comes Next</h2><p>The first version is a focused English guide. Future versions may add Chinese pages, brand data, tasting frameworks, product comparisons, and supplier disclosures if commercial relationships are introduced.</p>
  </article></section>
</BaseLayout>
