---
interface Props {
  type?: 'WebSite' | 'Article' | 'AboutPage';
  title: string;
  description: string;
  url: string;
}

const { type = 'Article', title, description, url } = Astro.props;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': type,
  name: title,
  headline: title,
  description,
  url,
  publisher: {
    '@type': 'Organization',
    name: 'Baijiu365',
  },
};
---
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
